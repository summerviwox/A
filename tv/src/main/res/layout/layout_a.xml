<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/a"
        android:background="@color/color_ff0000"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="@dimen/sw_200dp"
        android:layout_width="@dimen/sw_100dp"
        android:layout_height="@dimen/sw_100dp"/>

    <View
        android:id="@+id/c"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/a"
        android:layout_marginBottom="@dimen/sw_50dp"
        android:layout_width="match_parent"
        android:layout_height="1px"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@color/color_4cc417"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="@+id/c"
        android:layout_width="@dimen/sw_500dp"
        android:layout_height="@dimen/sw_700dp">

        <ScrollView
            android:clipToPadding="false"
            android:clipChildren="false"
            android:paddingTop="@dimen/sw_50dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:translationY="-150dp"
                    android:background="@color/color_7e354d"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/sw_300dp"/>
            </LinearLayout>

        </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>